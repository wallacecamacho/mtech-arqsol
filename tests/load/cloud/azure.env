# k6 environment — Azure deployment (Container Apps + Front Door)
#
# Usage:
#   export $(cat tests/load/cloud/azure.env | xargs)
#   k6 run -e SCENARIO=load tests/load/k6-scenarios.js
#
# Front Door hostname is provisioned by Bicep / Terraform.
# Replace with the actual Front Door endpoint hostname.

BASE_URL=https://cashflow-fd-<hash>.azurefd.net
SCENARIO=load

# Optional: Azure Load Testing (k6-compatible runner)
# AZP_LOAD_TEST_RESOURCE_GROUP=rg-cashflow-prod
# AZP_LOAD_TEST_RESOURCE_NAME=cashflow-load-test
