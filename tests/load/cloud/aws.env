# k6 environment — AWS deployment (ECS Fargate + ALB)
#
# Usage:
#   export $(cat tests/load/cloud/aws.env | xargs)
#   k6 run -e SCENARIO=load tests/load/k6-scenarios.js
#
# ALB DNS is provisioned by Terraform / CDK.
# Replace with the actual ALB DNS name or Route 53 alias.

BASE_URL=https://api.cashflow.example.com
SCENARIO=load

# Optional: k6 Cloud (Grafana) for distributed execution from AWS regions
# K6_CLOUD_TOKEN=<your-grafana-cloud-token>
