# =============================================================================
# CashFlow — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores antes de subir os serviços.
# NUNCA commite o arquivo .env com valores reais.
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=cashflow
POSTGRES_PASSWORD=cashflow_pass
POSTGRES_MULTIPLE_DATABASES=cashflow_entries,cashflow_consolidated

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=cashflow
RABBITMQ_DEFAULT_PASS=cashflow_pass

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=cashflow_pass

# ── JWT (OBRIGATÓRIO: troque por uma chave forte em produção — mín. 32 chars) ─
JWT_SECRET_KEY=CHANGE_ME_USE_A_STRONG_KEY_WITH_AT_LEAST_32_CHARACTERS
JWT_ISSUER=cashflow-gateway
JWT_AUDIENCE=cashflow-services
JWT_EXPIRY_MINUTES=60

# ── Observabilidade ──────────────────────────────────────────────────────────
SEQ_SERVER_URL=http://seq:5341
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
