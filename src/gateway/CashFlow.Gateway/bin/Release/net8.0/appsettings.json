{
  "Jwt": {
    "Key": "CHANGE_ME_IN_PRODUCTION_USE_ENV_VAR_AT_LEAST_32_CHARS",
    "Issuer": "cashflow-gateway",
    "Audience": "cashflow-services"
  },
  "Seq": {
    "ServerUrl": "http://seq:5341"
  },
  "Otlp": {
    "Endpoint": "http://jaeger:4317"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Yarp": "Warning"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "entries-route": {
        "ClusterId": "entries-cluster",
        "Match": {
          "Path": "/api/entries/{**catch-all}"
        },
        "Metadata": {
          "RateLimiterPolicy": "api-rate-limit"
        }
      },
      "consolidated-route": {
        "ClusterId": "consolidated-cluster",
        "Match": {
          "Path": "/api/consolidated/{**catch-all}"
        },
        "Metadata": {
          "RateLimiterPolicy": "api-rate-limit"
        }
      }
    },
    "Clusters": {
      "entries-cluster": {
        "Destinations": {
          "entries-primary": {
            "Address": "http://entries:8080/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/ready"
          }
        }
      },
      "consolidated-cluster": {
        "Destinations": {
          "consolidated-primary": {
            "Address": "http://consolidated:8080/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/ready"
          }
        }
      }
    }
  }
}
